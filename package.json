{
  "name": "@nodeloom/sdk",
  "version": "0.8.0",
  "description": "NodeLoom SDK for AI agent telemetry and monitoring",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./integrations/langchain": {
      "import": {
        "types": "./dist/esm/integrations/langchain.d.ts",
        "default": "./dist/esm/integrations/langchain.js"
      },
      "require": {
        "types": "./dist/cjs/integrations/langchain.d.cts",
        "default": "./dist/cjs/integrations/langchain.cjs"
      }
    },
    "./integrations/anthropic": {
      "import": {
        "types": "./dist/esm/integrations/anthropic.d.ts",
        "default": "./dist/esm/integrations/anthropic.js"
      },
      "require": {
        "types": "./dist/cjs/integrations/anthropic.d.cts",
        "default": "./dist/cjs/integrations/anthropic.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project tsconfig.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.1.0",
    "@anthropic-ai/sdk": ">= 1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "keywords": [
    "nodeloom",
    "ai",
    "agent",
    "telemetry",
    "monitoring",
    "observability",
    "langchain",
    "llm",
    "tracing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodeloom/nodeloom-sdk-typescript"
  },
  "bugs": {
    "url": "https://github.com/nodeloom/nodeloom-sdk-typescript/issues"
  },
  "homepage": "https://docs.nodeloom.io/sdk/typescript"
}
